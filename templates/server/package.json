{
	"name": "{{project_name}}",
	"version": "0.1.0",
	"description": "{{description}}",
	"type": "module",
	"repository": "{{repository}}",
	"author": "{{author}}",
	"license": "MIT",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "{{#if pkgMgr.yarn}}yarn{{else}}npm run{{/if}} lint && rimraf dist && npx rapidreact build",
		"dbuild": "rimraf dist && npx rapidreact build",
		"debug": "nodemon --legacy-watch --watch 'src/**/*' --ext 'ts' --exec 'tsx --inspect=0.0.0.0:9229 src/server.ts'",
		"docs": "typedoc --plugin typedoc-plugin-markdown --out docs/reference --target esnext --mode file src",
		"lint": "eslint ./src ./test",
		"local-audit": "{{#if pkgMgr.yarn}}yarn{{else}}npm{{/if}} install && yarn npm audit -A -R \"$@\"",
		"checkup": "{{#if pkgMgr.yarn}}yarn dlx{{else}}npx{{/if}} @yarnpkg/doctor \"$@\"",
		"dependency-check": "{{#if pkgMgr.yarn}}yarn dlx{{else}}npx{{/if}} depcheck \"$@\"",
		"report-coverage": "cat ./coverage/lcov.info | coveralls",
		"profile:process": "node --prof-process --call-graph",
		"profile:view": "npx speedscope",
		"start": "tsx src/server.ts",
		"test": "vitest run --coverage",
		"test:prod": "{{#if pkgMgr.yarn}}yarn{{else}}npm run{{/if}} lint && {{#if pkgMgr.yarn}}yarn{{else}}npm run{{/if}} test",
		"test:watch": "vitest --coverage",
		"version": "node scripts/update_helm_version.js && git add helm/* README.md single_node_install.sh",
		"postversion": "git push --follow-tags"
	},
	"prettier": {
		"printWidth": 120,
		"semi": true,
		"singleQuote": false,
		"tabWidth": 4,
		"trailingComma": "es5"
	},
	"dependencies": {
		"@rapidrest/core": "^1.3.0",
		{{#if features.react}}"@rapidrest/react": "^0.2.1",{{/if}}
		"@rapidrest/service-core": "^1.0.0-rc.10",
		"@types/node": "^25.9.3",
		"argon2": "^0.44.0",
		"axios": "^1.17.0",
		"lodash-es": "^4.18.1",
		{{#if features.mongodb}}"mongodb": "^7.3.0",{{/if}}
		"nconf": "^0.13.0",
		"openapi3-ts": "^4.6.0",
		"prom-client": "^15.1.3",
		{{#if features.react}}"react": "^19.2.7",{{/if}}
		{{#if features.react}}"react-dom": "^19.2.7",{{/if}}
		"reflect-metadata": "^0.2.2",
		"winston": "^3.19.0",
		"winston-transport": "^4.9.0"
	},
	"devDependencies": {
		"@swc/core": "^1.15.41",
		"@types/nconf": "^0.10.7",
		{{#if features.react}}"@types/react": "^19",{{/if}}
		{{#if features.react}}"@types/react-dom": "^19",{{/if}}
		{{#if features.react}}"@vitejs/plugin-react": "^6.0.3",{{/if}}
		"@vitest/coverage-v8": "^4.1.8",
		"coveralls": "^3.1.1",
		"eslint": "^10.5.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^63.0.2",
		"globals": "^17.6.0",
		{{#if features.redis}}"ioredis": "^5.11.1",{{/if}}
		{{#if features.mongodb}}"mongodb-memory-server": "^11.2.0",{{/if}}
		"nodemon": "^3.1.14",
		"rimraf": "^6.1.3",
		"tsx": "^4.22.4",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.12.0",
		{{#if features.postgresql}}"typeorm": "^0.3.20",{{/if}}
		"typescript": "^6.0.3",
		"unplugin-swc": "^1.5.9",
		"uuid": "^14.0.0",
		{{#if features.react}}"vite": "^8.1.0",{{/if}}
		"vitest": "^4.1.8"
	},
	"resolutions": {
		"semver": "^7.5.2",
		"axios": "^1.17.0",
		"json-schema": "^0.4.0"
	},
	{{#if pkgMgr.yarn}}"packageManager": "yarn@4.2.2",{{/if}}
	"engines": {
		"node": ">=24.0.0"
	}
}
